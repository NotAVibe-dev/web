---
// The "dependency sky": real package names drifting faintly behind the story.
// Ambient texture only — aria-hidden, never the subject. Opacity scales with the
// act so the sky "thickens" as the world comes to depend on the maintainer.
interface Props {
  opacity?: number;
  glow?: boolean;
}
const { opacity = 0.5, glow = false } = Astro.props;

// name, left%, top%, scale, depth(1 = far/slow, 3 = near/fast)
const pkgs: [string, number, number, number, number][] = [
  ['chalk', 8, 18, 1.0, 1],
  ['debug', 74, 12, 0.9, 2],
  ['express', 22, 68, 1.1, 3],
  ['lodash', 58, 30, 1.0, 1],
  ['semver', 86, 46, 0.85, 2],
  ['commander', 40, 82, 0.95, 3],
  ['ms', 15, 44, 0.8, 2],
  ['chokidar', 66, 74, 0.9, 1],
  ['ansi-styles', 33, 8, 0.85, 2],
  ['picocolors', 80, 84, 0.9, 3],
  ['minimatch', 5, 82, 0.85, 1],
  ['supports-color', 50, 56, 0.8, 2],
  ['glob', 92, 24, 0.8, 3],
  ['dotenv', 46, 20, 0.85, 1],
];
---

<div class="sky" aria-hidden="true" style={`--sky-op:${opacity}`}>
  {pkgs.map(([name, x, y, s, d]) => (
    <span
      class:list={['sky__pkg', `sky__pkg--d${d}`, { 'sky__pkg--glow': glow }]}
      style={`left:${x}%;top:${y}%;--s:${s}`}
    >{name}</span>
  ))}
</div>

<style>
  .sky {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
    opacity: var(--sky-op, 0.5);
  }
  .sky__pkg {
    position: absolute;
    font-family: var(--font-mono);
    font-size: calc(0.72rem * var(--s, 1));
    color: var(--text-faint);
    border: 1px solid var(--hairline);
    border-radius: var(--radius-pill);
    padding: 0.2em 0.7em;
    background: color-mix(in oklab, var(--ink-800), transparent 40%);
    white-space: nowrap;
    transform: translate(-50%, -50%);
    will-change: transform;
  }
  .sky__pkg--glow {
    color: color-mix(in oklab, var(--text-muted), var(--ember-500) 30%);
    border-color: color-mix(in oklab, var(--hairline-strong), var(--ember-700) 30%);
  }

  @media (prefers-reduced-motion: no-preference) {
    @supports (animation-timeline: view()) {
      .sky__pkg { animation: drift linear both; animation-timeline: view(); animation-range: cover; }
      .sky__pkg--d1 { --amp: 3%; }
      .sky__pkg--d2 { --amp: 7%; }
      .sky__pkg--d3 { --amp: 12%; }
      @keyframes drift {
        from { transform: translate(-50%, calc(-50% + var(--amp))); }
        to   { transform: translate(-50%, calc(-50% - var(--amp))); }
      }
    }
  }
</style>
